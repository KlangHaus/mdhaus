{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MdHaus",
  "version": "0.1.0",
  "identifier": "com.klanghaus.mdhaus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MdHaus",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Markdown editor with live preview",
    "longDescription": "MdHaus is an open-source macOS markdown editor with a split-pane live preview, built with Tauri, Rust, and Vue."
  }
}
