{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-set-title",
    "core:webview:allow-print",
    "dialog:default",
    "opener:default",
    "allow-read-workspace-git-info",
    "allow-read-workspace-git-changed-paths",
    "allow-read-file-git-last-author",
    "allow-read-workspace-git-contributors",
    "allow-git-commit-file",
    "allow-git-commit-workspace",
    "allow-read-file-git-head-content",
    "allow-git-push-workspace",
    "allow-git-pull-workspace",
    "allow-read-markdown-file",
    "allow-write-markdown-file",
    "allow-list-markdown-tree",
    "allow-search-markdown-content",
    "allow-workspace-watch",
    "allow-rename-markdown-path",
    "allow-create-markdown-folder",
    "allow-delete-markdown-path"
  ]
}
